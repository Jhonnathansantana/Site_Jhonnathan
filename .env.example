# Variables de entorno requeridas y opcionales para el proyecto.
# Copia este archivo como `.env` y completa los valores antes de ejecutar
# o configúralas en el panel de Netlify / Vercel.

# Obligatoria para el asistente de IA en netlify/functions/ai-assistant.js
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: modelo de OpenAI a usar. Por defecto: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import Search from '../../components/Search.tsx';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Blog — Jhonnathan.dev" description="Artículos sobre desarrollo web, tecnología y productos digitales.">
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="mb-8">
      <h1 class="mb-4 text-3xl font-bold tracking-tight">Blog</h1>
      <p class="mb-6 text-lg text-slate-600 dark:text-slate-400">
        Reflexiones y guías prácticas sobre desarrollo web, arquitectura de productos e integraciones con IA.
      </p>
      <Search client:only="react" />
    </div>

    {
      sortedPosts.length === 0 ? (
        <p class="text-slate-600 dark:text-slate-400">Próximamente publicaciones.</p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {sortedPosts.map((post) => (
            <Card
              title={post.data.title}
              link={{ href: `/blog/${post.id}/`, label: 'Leer artículo' }}
              highlighted={post.data.featured}
            >
              <p class="line-clamp-3 text-slate-600 dark:text-slate-400">{post.data.description}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="rounded-full bg-slate-100 px-2 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                    #{tag}
                  </span>
                ))}
              </div>
              <p class="mt-4 text-xs text-slate-500 dark:text-slate-500">
                {post.data.pubDate.toLocaleDateString('es-ES', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
            </Card>
          ))}
        </div>
      )
    }
  </section>
</Layout>

---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Prose from '../components/Prose.astro';

const title = 'Design System — Site Jhonnathan';
---

<Layout title={title} description="Catálogo de componentes y tokens de diseño del sitio.">
  <main class="mx-auto max-w-5xl px-4 py-12">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">Design System</h1>
    <p class="mb-8 text-lg text-slate-600 dark:text-slate-400">
      Referencia visual de tipografía, color, botones, tarjetas y bloques de contenido.
    </p>

    <section class="mb-12">
      <h2 class="mb-4 text-xl font-semibold">Tipografía</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <Card>
          <p class="text-4xl font-normal">Noto Sans 400</p>
          <p class="text-sm text-slate-500 dark:text-slate-400">Peso regular</p>
        </Card>
        <Card>
          <p class="text-4xl font-semibold">Noto Sans 600</p>
          <p class="text-sm text-slate-500 dark:text-slate-400">Peso semibold</p>
        </Card>
        <Card>
          <p class="text-4xl font-bold">Noto Sans 700</p>
          <p class="text-sm text-slate-500 dark:text-slate-400">Peso bold</p>
        </Card>
        <Card>
          <p class="text-base">El cuerpo usa Noto Sans para una lectura clara en cualquier dispositivo.</p>
        </Card>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="mb-4 text-xl font-semibold">Botones</h2>
      <div class="flex flex-wrap items-center gap-4">
        <Button variant="primary">Primario</Button>
        <Button variant="secondary">Secundario</Button>
        <Button variant="ghost">Ghost</Button>
        <Button href="#" variant="primary">Enlace</Button>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="mb-4 text-xl font-semibold">Tarjetas</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <Card title="Tarjeta simple">
          <p class="text-slate-600 dark:text-slate-400">Contenido genérico dentro de una Card con sombra y bordes suaves.</p>
        </Card>
        <Card title="Con acción" link={{ href: '#', label: 'Ver más' }}>
          <p class="text-slate-600 dark:text-slate-400">La tarjeta puede incluir un enlace de acción opcional.</p>
        </Card>
        <Card title="Destacada" highlighted>
          <p class="text-slate-600 dark:text-slate-400">Versión con borde de marca para contenido destacado.</p>
        </Card>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="mb-4 text-xl font-semibold">Prose</h2>
      <Prose>
        <h3>Encabezado dentro de Prose</h3>
        <p>
          Este bloque usa <strong>prose</strong> de Tailwind Typography para estilos de contenido largo:
          párrafos, listas, encabezados, citas y más.
        </p>
        <ul>
          <li>Item uno con tipografía legible.</li>
          <li>Item dos con espaciado consistente.</li>
          <li>Item tres listo para dark mode.</li>
        </ul>
        <blockquote>
          <p>“La buena tipografía es invisible; la mala es un obstáculo.”</p>
        </blockquote>
      </Prose>
    </section>
  </main>
</Layout>

---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

const title = 'Contacto — Jhonnathan.dev';
---

<Layout title={title} description="Formulario de contacto para servicios de desarrollo web, consultoría tecnológica e integraciones con IA.">
  <div class="mx-auto max-w-3xl px-4 py-12 sm:py-16">
    <header class="mb-10 text-center">
      <h1 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">Contacto</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400">Cuéntame lo que necesitas y te responderé lo antes posible.</p>
    </header>

    <form
      name="contacto"
      method="POST"
      data-netlify="true"
      netlify-honeypot="campo-extra"
      action="/contacto?enviado=true"
      class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900 sm:p-10"
    >
      <input type="hidden" name="form-name" value="contacto" />

      <p class="hidden">
        <label for="campo-extra">No completar este campo</label>
        <input id="campo-extra" name="campo-extra" />
      </p>

      <div class="mb-6">
        <label for="nombre" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300">Nombre</label>
        <input
          id="nombre"
          name="nombre"
          type="text"
          required
          autocomplete="name"
          class="w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-50"
          placeholder="Tu nombre"
        />
      </div>

      <div class="mb-6">
        <label for="email" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300">Correo electrónico</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-50"
          placeholder="tu@email.com"
        />
      </div>

      <div class="mb-6">
        <label for="asunto" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300">Asunto</label>
        <input
          id="asunto"
          name="asunto"
          type="text"
          required
          class="w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-50"
          placeholder="¿En qué puedo ayudarte?"
        />
      </div>

      <div class="mb-8">
        <label for="mensaje" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300">Mensaje</label>
        <textarea
          id="mensaje"
          name="mensaje"
          rows="5"
          required
          class="w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-50"
          placeholder="Describe brevemente tu proyecto o consulta..."
        ></textarea>
      </div>

      <div class="flex flex-wrap items-center justify-between gap-4">
        <Button type="submit" variant="primary" size="lg">Enviar mensaje</Button>
        <a
          href="mailto:hola@jhonnathan.dev"
          class="text-sm font-medium text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300"
        >
          Escribir por email →
        </a>
      </div>
    </form>
  </div>
</Layout>

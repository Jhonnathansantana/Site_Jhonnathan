---
import Layout from '../layouts/Layout.astro';
import { MonitorPanel } from '../components/MonitorPanel.tsx';
import { logger } from '../lib/logger';
---

<Layout title="Monitoreo — Jhonnathan.dev" description="Panel de monitoreo, logs y estado del sitio.">

  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">Monitoreo</h1>
    <p class="mb-8 text-slate-600 dark:text-slate-400">Panel central de logs, errores y rendimiento del sitio.</p>

    <div class="grid gap-6 md:grid-cols-3">
      <div class="rounded-lg border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-900">
        <h2 class="text-sm font-semibold text-slate-500 dark:text-slate-400">Estado</h2>
        <p class="mt-1 flex items-center gap-2 text-lg font-bold text-green-600">
          <span class="inline-block h-3 w-3 rounded-full bg-green-500"></span>
          Operacional
        </p>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-900">
        <h2 class="text-sm font-semibold text-slate-500 dark:text-slate-400">Entorno</h2>
        <p class="mt-1 text-lg font-bold text-slate-700 dark:text-slate-300">
          {import.meta.env.MODE}
        </p>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-900">
        <h2 class="text-sm font-semibold text-slate-500 dark:text-slate-400">Sentry DSN</h2>
        <p class="mt-1 text-lg font-bold text-slate-700 dark:text-slate-300">
          {import.meta.env.PUBLIC_SENTRY_DSN ? 'Configurado' : 'No configurado'}
        </p>
      </div>
    </div>

    <div class="mt-8">
      <MonitorPanel client:load />
    </div>
  </section>

</Layout>

<script>
  import { logger } from '../lib/logger';
  logger.info('Monitoreo', 'Página de monitoreo cargada');
</script>
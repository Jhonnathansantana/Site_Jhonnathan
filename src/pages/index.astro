---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

const title = 'Jhonnathan.dev — Desarrollador web y asesoría tecnológica';
---

<Layout title={title} description="Sitio personal de Jhonnathan: desarrollo web, consultoría tecnológica e integraciones con IA.">
  <section class="relative overflow-hidden px-4 py-20 sm:py-28">
    <div class="mx-auto max-w-4xl text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">Hola, soy Jhonnathan</p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
        Construyo sitios web modernos y ayudo a equipos a aprovechar la IA.
      </h1>
      <p class="mx-auto mb-10 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
        Desarrollador web enfocado en performance, accesibilidad y experiencia de usuario. También asesoro en arquitectura de productos e integraciones inteligentes.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <Button href="/servicios" variant="primary" size="lg">Ver servicios</Button>
        <Button href="/contacto" variant="secondary" size="lg">Hablemos</Button>
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-slate-50 px-4 py-16 dark:border-slate-800 dark:bg-slate-900">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="text-center">
          <p class="text-3xl font-bold text-brand-600 dark:text-brand-400">+5</p>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">años de experiencia</p>
        </div>
        <div class="text-center">
          <p class="text-3xl font-bold text-brand-600 dark:text-brand-400">20+</p>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">proyectos entregados</p>
        </div>
        <div class="text-center">
          <p class="text-3xl font-bold text-brand-600 dark:text-brand-400">100%</p>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">enfoque en resultados</p>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-16">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="mb-4 text-2xl font-semibold">¿Tienes un proyecto en mente?</h2>
      <p class="mb-8 text-slate-600 dark:text-slate-400">Cuéntame lo que necesitas y te ayudo a definir el mejor camino.</p>
      <Button href="/contacto" variant="primary">Escríbeme</Button>
    </div>
  </section>
</Layout>

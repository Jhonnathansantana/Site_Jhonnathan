---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
---

<Layout title="Site Jhonnathan" description="Proyecto Astro 5 + React + Tailwind CSS.">
  <section class="flex min-h-[calc(100vh-8rem)] flex-col items-center justify-center px-4 text-center">
    <h1 class="mb-4 text-4xl font-bold tracking-tight sm:text-5xl">Site Jhonnathan</h1>
    <p class="mb-8 max-w-xl text-lg text-slate-600 dark:text-slate-400">
      Proyecto Astro 5 + React + Tailwind CSS con design system, modo oscuro persistente y layout responsive.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <Button href="/design-system" variant="primary">Ver Design System</Button>
      <Button href="#" variant="secondary">Saber más</Button>
    </div>
  </section>
</Layout>

---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';
import projectsData from '../data/projects.json';

const title = 'Portafolio — Jhonnathan.dev';
---

<Layout title={title} description="Proyectos realizados por Jhonnathan: sitios web, dashboards, integraciones con IA y automatización.">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:py-16">
    <header class="mb-12 text-center">
      <h1 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">Portafolio</h1>
      <p class="mx-auto max-w-2xl text-lg text-slate-600 dark:text-slate-400">
        Una selección de proyectos personales y profesionales construidos con enfoque en claridad, performance y experiencia de usuario.
      </p>
    </header>

    <section class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        projectsData.projects.map((project) => (
          <Card title={project.title} link={project.link}>
            <p class="mb-4 text-slate-600 dark:text-slate-400">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="rounded-full bg-brand-50 px-2.5 py-1 text-xs font-medium text-brand-700 dark:bg-brand-950 dark:text-brand-300">
                  {tag}
                </span>
              ))}
            </div>
          </Card>
        ))
      }
    </section>

    <section class="mt-16 rounded-2xl border border-slate-200 bg-slate-50 px-6 py-10 text-center dark:border-slate-800 dark:bg-slate-900 sm:px-10">
      <h2 class="mb-3 text-2xl font-semibold">¿Tienes un proyecto en mente?</h2>
      <p class="mb-6 text-slate-600 dark:text-slate-400">Me encanta colaborar en productos con propósito. Cuéntame tu idea.</p>
      <Button href="/contacto" variant="primary" size="lg">Trabajemos juntos</Button>
    </section>
  </div>
</Layout>

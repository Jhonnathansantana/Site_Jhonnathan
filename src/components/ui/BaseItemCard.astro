---
import Tag from "./Tag.astro";

interface Props {
    title: string;
    href: string;
    description?: string;
    date?: string;
    authors?: string;
    extra?: string;
    tags?: string[];
    linkText?: string;
}

const {
    title,
    href,
    description,
    date,
    authors,
    extra,
    tags = [],
    linkText = "Ver más",
} = Astro.props;
---

<article class="py-4 border-b border-dashed border-border last:border-b-0 transition-opacity hover:opacity-95">
    <div class="flex flex-col gap-2">
        <a href={href} class="text-lg lg:text-xl font-bold leading-tight text-foreground hover:text-accent hover:underline underline-offset-4">
            {title}
        </a>

        <div class="flex flex-wrap items-center gap-3 text-xs lg:text-sm text-foreground/70"
        >
            {date && <span>{date}</span>}
            {authors && <span>{authors}</span>}
            {extra && <span>{extra}</span>}
        </div>

        {tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                    <Tag tag={tag} />
                ))}
            </div>
        )}

        {description && (
            <p class="text-sm lg:text-base text-foreground/80 leading-relaxed line-clamp-2 m-0">
                {description}
            </p>
        )}

        <div class="mt-2">
            <a href={href} class="text-sm font-bold text-foreground hover:text-accent whitespace-nowrap">
                {linkText}
            </a>
        </div>
    </div>
</article>

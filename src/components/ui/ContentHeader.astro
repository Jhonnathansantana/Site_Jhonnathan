---
interface Props {
    title: string;
    subtitle?: string;
    meta?: { label?: string; value: string }[];
}

const { title, subtitle, meta = [] } = Astro.props;
---

<header class="mb-6 lg:mb-8">
    <h1 class="text-2xl lg:text-3xl font-extrabold tracking-tight text-foreground mb-2">{title}</h1>
    {subtitle && <p class="text-base lg:text-lg text-foreground/80 leading-relaxed">{subtitle}</p>}
    {meta.length > 0 && (
        <div class="flex flex-wrap gap-x-4 gap-y-1 mt-2 text-sm text-foreground/70">
            {meta.map((item) => (
                <span>
                    {item.label && <span class="text-foreground/50">{item.label}: </span>}
                    {item.value}
                </span>
            ))}
        </div>
    )}
</header>

---
import { SITE, THEME_CONFIG, SETTINGS } from "../../config";
import Icon from "../ui/Icon.astro";

const currentYear = new Date().getFullYear();
const showToggle = THEME_CONFIG.lightAndDark;
const showDevTools = SETTINGS.devMode?.showDevTools !== false;
---

<footer class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 px-4 py-4 lg:px-6 text-sm text-foreground/80 border-t border-border">
    <div class="flex flex-wrap items-center gap-2">
        <span>© {currentYear} {SITE.author.name}.{</span>
        <span>
            Hecho con
            <a
                href="https://astro.build"
                target="_blank"
                rel="noopener noreferrer"
                class="underline underline-offset-4 font-semibold hover:text-accent"
            >
                Astro
            </a>.
        </span>
    </div>

    <div class="flex items-center gap-2">
        <a
            href="/rss.xml"
            aria-label="RSS Feed"
            title="RSS Feed"
            target="_blank"
            rel="noreferrer"
            class="w-8 h-8 flex items-center justify-center rounded-full border border-border bg-surface hover:bg-accent hover:border-accent hover:text-background transition-all"
        >
            <Icon name="RSS" size={16} />
        </a>

        {showToggle && (
            <button
                id="theme-toggle"
                aria-label="Cambiar tema oscuro/claro"
                class="w-8 h-8 flex items-center justify-center rounded-full border border-border bg-surface hover:bg-accent hover:border-accent hover:text-background transition-all"
            >
                <Icon name="Sun" size={16} class="hidden dark:block" />
                <Icon name="Moon" size={16} class="block dark:hidden" />
            </button>
        )}
    </div>
</footer>

---
export interface Props {
  title?: string;
  highlighted?: boolean;
  link?: { href: string; label: string };
  class?: string;
}

const { title, highlighted = false, link, class: extraClass = '' } = Astro.props;

const base =
  'rounded-xl border bg-white p-6 shadow-sm transition dark:bg-slate-900';
const highlightedClass = highlighted
  ? 'border-brand-500 dark:border-brand-400'
  : 'border-slate-200 dark:border-slate-800';

const classes = [base, highlightedClass, extraClass].join(' ');
---

<article class={classes}>
  {title && <h3 class="mb-2 text-lg font-semibold">{title}</h3>}
  <div class="text-slate-700 dark:text-slate-300">
    <slot />
  </div>
  {
    link && (
      <div class="mt-4">
        <a
          href={link.href}
          class="text-sm font-semibold text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300"
        >
          {link.label} →
        </a>
      </div>
    )
  }
</article>
